# ============================================================
#  SUPABASE LOG AI ASSISTANT - Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# --- SUPABASE (Required for log fetching) ---
# Your Supabase project URL (e.g. https://xxxx.supabase.co)
SUPABASE_URL=https://your-project-ref.supabase.co

# Personal Access Token — generate at https://supabase.com/dashboard/account/tokens
# Must start with sbp_
SUPABASE_PAT=sbp_your_personal_access_token

# --- GEMINI AI (Required for AI Chat) ---
# Generate at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# --- FRONTEND (Next.js) ---
# These are used by the Next.js dev server
NEXT_PUBLIC_APP_NAME="Supabase Log AI Assistant"
NEXT_PUBLIC_LOG_FETCH_INTERVAL=300000
NEXT_PUBLIC_MAX_LOGS_PER_QUERY=1000
NEXT_PUBLIC_PAGE_SIZE=50

# --- BACKEND (Set when deploying to Render) ---
# The full URL of your deployed Render backend service
# e.g.  https://supabase-log-assistant-api.onrender.com
BACKEND_API_URL=http://localhost:8000

# Comma-separated list of frontend origins allowed to call the backend
# e.g.  https://your-app.vercel.app,https://www.your-domain.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
